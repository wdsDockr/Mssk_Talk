# ============================================================
# Mssk_Talk — Environment Variables
# Copy this file as reference when setting up Cloudflare Pages
# Environment Variables (Settings → Environment Variables)
# ============================================================

# ── Required ─────────────────────────────────────────────────

# Supabase project URL
# Found in: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to expose in browser)
# Found in: Supabase Dashboard → Settings → API → Project API keys → anon public
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service_role key (keep secret — server-side only)
# Found in: Supabase Dashboard → Settings → API → Project API keys → service_role
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin panel login password
ADMIN_PASSWORD=your-secure-password

# ── Notifications (optional) ──────────────────────────────────
# Configure either or both. Both work independently.

# Telegram — get token from @BotFather, chat ID from @userinfobot
NOTIFY_TG_TOKEN=
NOTIFY_TG_CHAT_ID=

# Email via Resend (https://resend.com, free tier: 3,000/month)
# Sender domain must be verified in Resend dashboard
NOTIFY_RESEND_KEY=
NOTIFY_EMAIL_FROM=hello@yourdomain.com
NOTIFY_EMAIL_TO=you@youremail.com
